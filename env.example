# MongoDB Atlas 연결 정보
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority

# 서버 설정
PORT=3000
NODE_ENV=development

# 데이터베이스 이름
JOB_DATA_DB=job_data
SURVEY_QUESTIONS_DB=survey_questions
SURVEY_DATA_DB=survey_data
REFERENCE_DATA_DB=reference_data
USER_DATA_DB=user_data

# JWT
JWT_SECRET=lighthouse-dev-secret

# S3 인증사진 업로드 (진로달성)
# 자격증명을 비워두면 SDK 기본 체인(~/.aws, 인스턴스 프로파일)을 사용
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=lighthouse-career-fe
S3_UPLOAD_PREFIX=uploads
# 공개 조회 URL prefix (CloudFront 도메인). 미설정 시 S3 가상호스팅 URL 폴백
S3_UPLOAD_PUBLIC_BASE=https://lighthouse.career